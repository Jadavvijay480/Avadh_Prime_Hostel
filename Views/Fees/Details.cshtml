@model AVADH_PRIME_Consume.Models.FeesModel



<!DOCTYPE html>
<html>
<head>
    <title>Fees Profile</title>

    <link href="~/css/stylesheet.css" rel="stylesheet" />
</head>

<body>

<main id="main" class="main">

    <!-- HEADER -->
    <div class="header-bar">
        <div class="header-title">FEES DETAILS</div>

        <div>
            <a asp-action="Edit"
               asp-route-Fees_Id="@Model.Fees_Id"
               class="btn">EDIT</a>

            <a asp-action="Index" class="btn">BACK</a>
        </div>
    </div>

    <!-- GRID -->
    <div class="main-grid">

            <!-- ICON BOX -->
            <div class="box student-box">
                <i class="bi bi-cash-coin" style="font-size:80px;color:darkolivegreen;"></i>
                <div class="student-name">@Model.Fee_Type</div>
            </div>

        <!-- BASIC INFO -->
        <div class="box">
            <div class="title">Basic Info</div>
            <table class="kv">
                <tr><td class="key">Fees ID</td><td class="colon">:</td><td class="value">@Model.Fees_Id</td></tr>
                <tr><td class="key">Student ID</td><td class="colon">:</td><td class="value">@Model.Student_Id</td></tr>
                <tr><td class="key">Fee Type</td><td class="colon">:</td><td class="value">@Model.Fee_Type</td></tr>
                <tr><td class="key">Semester</td><td class="colon">:</td><td class="value">@Model.Semester</td></tr>
                <tr><td class="key">Year</td><td class="colon">:</td><td class="value">@Model.Year</td></tr>
            </table>
        </div>

        <!-- STATUS -->
        <div class="box">
            <div class="title">Status Info</div>
            <table class="kv">
                <tr><td class="key">Payment</td><td class="colon">:</td><td class="value status">@Model.Payment_Status</td></tr>
                <tr><td class="key">Active</td><td class="colon">:</td><td class="value">@(Model.IsActive ? "Yes" : "No")</td></tr>
            </table>
        </div>

        

        <!-- AMOUNT -->
        <div class="box">
            <div class="title">Amount Info</div>
            <table class="kv">
                <tr><td class="key">Total</td><td class="colon">:</td><td class="value">₹@Model.Total_Amount</td></tr>
                <tr><td class="key">Paid</td><td class="colon">:</td><td class="value">₹@Model.Paid_Amount</td></tr>
                <tr><td class="key">Due</td><td class="colon">:</td><td class="value">₹@Model.Due_Amount</td></tr>
                <tr><td class="key">Late Fine</td><td class="colon">:</td><td class="value">₹@Model.Late_Fine</td></tr>
            </table>
        </div>

        <!-- PAYMENT -->
        <div class="box">
            <div class="title">Payment Info</div>
            <table class="kv">
                <tr><td class="key">Mode</td><td class="colon">:</td><td class="value">@Model.Payment_Mode</td></tr>
                <tr><td class="key">Transaction</td><td class="colon">:</td><td class="value">@Model.Transaction_Id</td></tr>
                <tr><td class="key">Status</td><td class="colon">:</td><td class="value status">@Model.Payment_Status</td></tr>
            </table>
        </div>

        <!-- DATES -->
        <div class="box">
            <div class="title">Date Info</div>
            <table class="kv">
                <tr><td class="key">Fee Date</td><td class="colon">:</td><td class="value">@Model.Fee_Date.ToString("dd-MM-yyyy")</td></tr>
                <tr><td class="key">Due Date</td><td class="colon">:</td><td class="value">@Model.Due_Date.ToString("dd-MM-yyyy")</td></tr>
                <tr>
                    <td class="key">Payment</td>
                    <td class="colon">:</td>
                    <td class="value">
                        @(Model.Payment_Date?.ToString("dd-MM-yyyy") ?? "-")
                    </td>
                </tr>
            </table>
        </div>

        <!-- SUMMARY -->
        <div class="box">
            <div class="title">Summary</div>
            <table class="kv">
                <tr><td class="key">Status</td><td class="colon">:</td><td class="value status">@Model.Payment_Status</td></tr>
                <tr><td class="key">Active</td><td class="colon">:</td><td class="value">@(Model.IsActive ? "Yes" : "No")</td></tr>
            </table>
        </div>

        <!-- AUDIT -->
        <div class="box">
            <div class="title">Audit</div>
            <table class="kv">
                <tr><td class="key">Created</td><td class="colon">:</td><td class="value">@Model.CreatedAt.ToString("dd-MM-yyyy HH:mm")</td></tr>
                <tr>
                    <td class="key">Updated</td>
                    <td class="colon">:</td>
                    <td class="value">
                        @(Model.UpdatedAt?.ToString("dd-MM-yyyy HH:mm") ?? "-")
                    </td>
                </tr>
            </table>
        </div>

    </div>

</main>

</body>
</html>


