@model AVADH_PRIME_Consume.Models.FeesModel

@{
    ViewData["Title"] = Model.Fees_Id == 0 ? "Add Fees" : "Edit Fees";
}

<main id="main" class="main">

    <!-- HEADER -->
    <div class="pagetitle d-flex justify-content-between align-items-center">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
    </div>

    <section class="section dashboard pt-2">
        <div class="card shadow-sm p-4">

            <form asp-action="Add" method="post">

                @Html.AntiForgeryToken()

                <!-- HIDDEN -->
                <input type="hidden" asp-for="Fees_Id" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="UpdatedAt" />

                <!-- BASIC INFO -->
                <h5 class="mb-3">📌 Basic Info</h5>
                <div class="row">
                    <div class="col-md-4">
                        <input asp-for="Student_Id" type="number" class="form-control mb-2" placeholder="Student ID" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Fee_Type" class="form-control mb-2" placeholder="Fee Type (Hostel, Mess...)" />
                    </div>

                    <div class="col-md-4">
                        <select asp-for="Payment_Status" class="form-control mb-2">
                            <option value="">Select Status</option>
                            <option>Paid</option>
                            <option>Pending</option>
                            <option>Partial</option>
                        </select>
                    </div>
                </div>

                <!-- AMOUNT -->
                <h5 class="mt-3 mb-3">💰 Amount Info</h5>
                <div class="row">
                    <div class="col-md-3">
                        <input asp-for="Total_Amount" type="number" step="0.01" class="form-control mb-2" placeholder="Total Amount" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Paid_Amount" type="number" step="0.01" class="form-control mb-2" placeholder="Paid Amount" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Due_Amount" type="number" step="0.01" class="form-control mb-2" placeholder="Due Amount" readonly />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Late_Fine" type="number" step="0.01" class="form-control mb-2" placeholder="Late Fine" />
                    </div>
                </div>

                <!-- PAYMENT -->
                <h5 class="mt-3 mb-3">💳 Payment Info</h5>
                <div class="row">
                    <div class="col-md-4">
                        <input asp-for="Payment_Mode" class="form-control mb-2" placeholder="Payment Mode (Cash, UPI...)" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Transaction_Id" class="form-control mb-2" placeholder="Transaction ID" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Payment_Date" type="date" class="form-control mb-2" />
                    </div>
                </div>

                <!-- DATES -->
                <h5 class="mt-3 mb-3">📅 Date Info</h5>
                <div class="row">
                    <div class="col-md-4">
                        <input asp-for="Fee_Date" type="date" class="form-control mb-2" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Due_Date" type="date" class="form-control mb-2" />
                    </div>
                </div>

                <!-- ACADEMIC -->
                <h5 class="mt-3 mb-3">🎓 Academic Info</h5>
                <div class="row">
                    <div class="col-md-4">
                        <input asp-for="Semester" type="number" class="form-control mb-2" placeholder="Semester" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Year" type="number" class="form-control mb-2" placeholder="Year" />
                    </div>
                </div>

                <!-- STATUS -->
                <h5 class="mt-3 mb-3">⚙️ Status</h5>
                <div class="row">
                    <div class="col-md-4">
                        <select asp-for="IsActive" class="form-control mb-2">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>

                <!-- SUBMIT -->
                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success">
                        @(Model.Fees_Id == 0 ? "➕ Add Fees" : "✏️ Update Fees")
                    </button>
                </div>

            </form>

        </div>
    </section>

</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- AUTO CALCULATE DUE -->
    <script>
        const total = document.getElementById("Total_Amount");
        const paid = document.getElementById("Paid_Amount");
        const due = document.getElementById("Due_Amount");

        function calculateDue() {
            const t = parseFloat(total.value) || 0;
            const p = parseFloat(paid.value) || 0;
            due.value = (t - p).toFixed(2);
        }

        total.addEventListener("input", calculateDue);
        paid.addEventListener("input", calculateDue);
    </script>
}