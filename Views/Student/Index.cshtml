@model List<AVADH_PRIME_Consume.Models.StudentModel>

@{
    ViewData["Title"] = "Student List";
}


<style>
    .hidden {
        display: none !important;
    }
    .main {
        background-color: #f5c068;
        min-height: 100vh;
        padding: 20px;
    }

    /* THEAD custom color */
    #attendanceTable thead {
        background-color: #5b1f17 !important;
        color: white !important;
    }

    /* TBODY custom color */
    #attendanceTable tbody {
        background-color: #f5c068;
        color: white;
    }

        /* Optional: table row hover effect */
        #attendanceTable tbody tr:hover {
            background-color: #e0ad55;
        }



    .btn-circle {
        width: 45px;
        height: 45px;
        background: #5b1f17;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        font-size: 24px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        .btn-circle:hover {
            background: #73271d;
            transform: scale(1.08);
            color: white;
        }

    .id-card {
        width: 100%;
        max-width: 320px;
        height: 520px;
        background: linear-gradient(180deg, #5b1f17 0%, #3a110a 100%);
        border-radius: 16px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.25);
    }

    .logo-header {
        background: #3b1913;
        height: 110px;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 10px;
    }

    .main-title {
        color: white;
        font-size: 18px;
        margin: 0;
        font-weight: 700;
    }

    .subtitle-bar {
        background: #ee7216;
        color: white;
        font-size: 11px;
        padding: 4px 14px;
        margin-top: 5px;
        border-radius: 4px 4px 10px 10px;
        display: inline-block;
        font-weight: 700;
    }

    .shape-container {
        position: absolute;
        top: 110px;
        width: 100%;
        height: 150px;
    }

    .shape-right {
        background: #73271d;
        height: 100%;
        clip-path: polygon(0 40%, 100% 0, 100% 100%, 0% 100%);
    }

    .shape-left {
        position: absolute;
        top: 0;
        width: 100%;
        height: 85%;
        background: #40140d;
        clip-path: polygon(0 0, 100% 20%, 0 80%);
    }

    .avatar-wrapper {
        position: absolute;
        top: 75px;
        left: 50%;
        transform: translateX(-50%);
        width: 110px;
        height: 125px;
        background: #f5c068;
        clip-path: polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
    }

    .avatar-inner {
        width: 100px;
        height: 115px;
        margin: auto;
        overflow: hidden;
        clip-path: inherit;
    }

        .avatar-inner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .card-body {
        position: absolute;
        top: 210px;
        width: 100%;
        color: white;
        text-align: center;
    }

    .enr-number {
        font-size: 16px;
        font-weight: 700;
    }

    .details {
        width: 85%;
        margin: auto;
    }

    .detail-row {
        display: flex;
        font-size: 11px;
        padding: 6px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .detail-label {
        width: 40%;
        color: #ddd;
        text-align: left;
    }

    .detail-separator {
        width: 10%;
    }

    .detail-value {
        width: 50%;
        text-align: left;
    }

    .card-footer {
        position: absolute;
        bottom: 15px;
        width: 100%;
        text-align: center;
        background: #f5c068
    }

    .btn-theme {
        background: #5b1f17;
        color: white;
        border: none;
    }

        .btn-theme:hover {
            background: #73271d;
            color: white;
        }

    .btn-theme-outline {
        background: transparent;
        border: 1px solid #73271d;
        color: white;
    }

        .btn-theme-outline:hover {
            background: white;
            color: #5b1f17;
        }

    .btn-theme-danger {
        background: #40140d;
        color: white;
        border: none;
    }

        .btn-theme-danger:hover {
            background: #73271d;
            color: white;
        }

    .dashboard-header h1 {
        color: #5b1f17;
    }

    .dashboard-header .breadcrumb-item,
    .dashboard-header .breadcrumb-item a {
        color: #5b1f17;
    }

        .dashboard-header .breadcrumb-item.active {
            color: #5b1f17;
        }

    #studentSearch {
        border: 1px solid #5b1f17;
    }

        #studentSearch:focus {
            border-color: #5b1f17;
            box-shadow: 0 0 0 0.2rem rgba(91, 31, 23, 0.25); /* soft outline glow */
            outline: none;
        }
</style>


<main id="main" class="main">

    <!-- HEADER -->
    <div class="pagetitle d-flex align-items-center justify-content-between flex-wrap gap-2">

        <!-- LEFT -->
        <div class="dashboard-header">
            <h1 class="mb-1">Dashboard</h1>
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active">🎓 Student Management</li>
                </ol>
            </nav>
        </div>

        <!-- SEARCH -->
        <div class="flex-grow-1 px-3" style="max-width: 400px;">
            <div class="position-relative">
                <input type="text"
                       id="studentSearch"
                       class="form-control pe-5"
                       placeholder="Search student ID..." />

                <span class="position-absolute top-50 end-0 translate-middle-y me-3 text-muted">
                    🔍
                </span>
            </div>
        </div>

        <!-- ADD BUTTON -->
        <div>
            <a asp-action="Add" class="btn-circle">
                +
            </a>
        </div>
    </div>

    <!-- CONTENT -->
    <section class="section dashboard">
        <div class="row g-4">

            <!-- ALERTS -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            <!-- STUDENT CARDS -->
            @foreach (var student in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 d-flex justify-content-center student-item">

                    <div class="id-card"
                         data-name="@($"{student.First_Name} {student.Last_Name}")"
                         data-enroll="@student.H_Enrollment_No">

                        <!-- HEADER -->
                        <div class="card-header logo-header">
                            <div class="logo-mini">
                                <h1 class="main-title">Avadh Prime</h1>
                                <div class="subtitle-bar">BOY'S HOSTEL</div>
                            </div>
                        </div>

                        <!-- SHAPES -->
                        <div class="shape-container">
                            <div class="shape-right"></div>
                            <div class="shape-left"></div>
                        </div>

                        <!-- IMAGE -->
                        <div class="avatar-wrapper">
                            <div class="avatar-inner">
                                <img src="@(
                                     string.IsNullOrEmpty(student.student_image)
                                     ? "/images/no-image.png"
                                     : student.student_image
)"
                                 onerror="this.src='/images/no-image.png';" />
                        </div>
                    </div>
                  
                        <!-- BODY -->
                        <div class="card-body">

                            <h2 class="enr-number">
                                @student.H_Enrollment_No
                            </h2>

                            <div class="role-divider">
                                <span>Student</span>
                            </div>

                            <div class="details">

                                <div class="detail-row">
                                    <div class="detail-label">Name</div>
                                    <div class="detail-separator">:</div>
                                    <div class="detail-value">
                                        @student.First_Name @student.Last_Name
                                    </div>
                                </div>

                                <div class="detail-row">
                                    <div class="detail-label">Phone</div>
                                    <div class="detail-separator">:</div>
                                    <div class="detail-value">
                                        @student.Phone
                                    </div>
                                </div>

                                <div class="detail-row">
                                    <div class="detail-label">Email</div>
                                    <div class="detail-separator">:</div>
                                    <div class="detail-value">
                                        @student.Email
                                    </div>
                                </div>

                                <div class="detail-row">
                                    <div class="detail-label">Course</div>
                                    <div class="detail-separator">:</div>
                                    <div class="detail-value">
                                        @student.Course (@student.Semester)
                                    </div>
                                </div>

                                <div class="detail-row">
                                    <div class="detail-label">College</div>
                                    <div class="detail-separator">:</div>
                                    <div class="detail-value">
                                        @student.CollegeName
                                    </div>
                                </div>

                                <div class="detail-row">
                                    <div class="detail-label">City</div>
                                    <div class="detail-separator">:</div>
                                    <div class="detail-value">
                                        @student.City
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer">

                            <div class="footer-actions d-flex justify-content-center gap-3">

                                <!-- DETAILS -->
                                <a asp-action="Details"
                                   asp-route-Student_Id="@student.Student_Id"
                                   class="btn btn-theme btn-sm">
                                    👁
                                </a>

                                <!-- EDIT -->
                                <a asp-action="Edit"
                                   asp-route-Student_Id="@student.Student_Id"
                                   class="btn btn-theme-outline btn-sm">
                                    ✏️
                                </a>

                                <!-- DELETE -->
                                <form asp-action="Delete"
                                      method="post"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden"
                                           name="Student_Id"
                                           value="@student.Student_Id" />

                                    <button type="submit"
                                            class="btn btn-theme-danger btn-sm"
                                            onclick="return confirm('Are you sure you want to delete this student?');">
                                        🗑
                                    </button>
                                </form>

                            </div>
                        </div>

                    </div>
                </div>
            }

        </div>
    </section>

</main>


<script>
   document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("studentSearch");
        const cards = document.querySelectorAll(".student-item");

        searchInput.addEventListener("input", function () {

            const query = this.value.toLowerCase().trim();
            const keywords = query.split(/\s+/).filter(Boolean);

            cards.forEach(item => {

                const card = item.querySelector(".id-card");

                const data = [
                    card.dataset.name,
                    card.dataset.enroll,
                    card.dataset.phone,
                    card.dataset.email,
                    card.dataset.course,
                    card.dataset.city
                ].join(" ").toLowerCase();

                const match = keywords.every(k => data.includes(k));

                item.classList.toggle("hidden", !match);

            });

        });

    });
</script>

