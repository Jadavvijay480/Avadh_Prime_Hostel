@model List<AVADH_PRIME_Consume.Models.RoomsAllocationModel>

@{
    ViewData["Title"] = "Room Allocation";
}

<style>
    /* STATUS BADGE */
    .badge-active {
        background-color: #28a745;
        color: #fff;
    }

    .badge-vacated {
        background-color: #dc3545;
        color: #fff;
    }

    .badge-default {
        background-color: #007bff;
        color: #fff;
    }

    /* CARD */
    .card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 6px 18px rgba(0,0,0,0.15);
        overflow: hidden;
    }

    /* TABLE HEADER */
    #roomTable thead {
        background: linear-gradient(45deg, #5b1f17, #73271d);
    }

        #roomTable thead th {
            color: #fff;
            padding: 14px;
            font-size: 14px;
            text-transform: uppercase;
        }

    /* TABLE BODY */
    #roomTable tbody tr {
        background-color: #fffaf5;
        transition: 0.2s;
    }

        #roomTable tbody tr:nth-child(even) {
            background-color: #fde8d7;
        }

        #roomTable tbody tr:hover {
            background-color: #f8d7c4;
            transform: scale(1.002);
        }

    #roomTable td {
        padding: 12px;
        font-size: 13px;
        border-bottom: 1px solid #f1d2b8;
    }

    /* BUTTONS */
    .btn-warning {
        background-color: #f5c068;
        border: none;
        color: #5b1f17;
    }

    .btn-danger {
        background-color: #5b1f17;
        border: none;
    }

        .btn-danger:hover {
            background-color: #73271d;
        }

    /* ADD BUTTON */
    .btn-circle {
        width: 45px;
        height: 45px;
        background: #5b1f17;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 22px;
        text-decoration: none;
    }

        .btn-circle:hover {
            background: #73271d;
            transform: scale(1.08);
        }

    /* SEARCH */
    #roomSearch {
        border: 1px solid #5b1f17;
    }

        #roomSearch:focus {
            border-color: #5b1f17;
            box-shadow: 0 0 0 0.2rem rgba(91,31,23,0.25);
        }

    .main {
        background-color: #f5c068;
    }
</style>

<main class="main">

    <!-- HEADER -->
    <div class="pagetitle d-flex justify-content-between align-items-center flex-wrap gap-2">

        <div>
            <h1 style="color:#5b1f17;">Room Allocation</h1>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="#" style="color:#5b1f17;">Home</a>
                </li>
                <li class="breadcrumb-item active" style="color:#5b1f17;">
                    🛏 Room Management
                </li>
            </ol>
        </div>

        <!-- SEARCH -->
        <div class="flex-grow-1 px-3" style="max-width: 400px;">
            <input type="text" id="roomSearch" class="form-control"
                   placeholder="Search student / bed..." />
        </div>

        <!-- ADD BUTTON -->
        <a asp-action="Add" class="btn-circle">+</a>

    </div>

    <!-- BODY -->
    <section class="section dashboard">
        <div class="row">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <div class="col-12">
                <div class="card">
                    <div class="card-body pt-3">

                        <div class="table-responsive">

                            <table class="table text-center align-middle" id="roomTable">

                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Student</th>
                                        <th>Bed No</th>
                                        <th>Allocation</th>
                                        <th>Vacate</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@item.Allocation_Id</td>
                                                <td>@item.Student_Id</td>
                                                <td>@item.Bed_No</td>
                                                <td>@item.Allocation_Date.ToString("dd-MM-yyyy")</td>
                                                <td>@item.Vacate_Date.ToString("dd-MM-yyyy")</td>

                                                <td>
                                                    <span class="badge
                                                                @(item.Status == "Active" ? "badge-active" :
                                                                                                                    item.Status == "Vacated" ? "badge-vacated" :
                                                                                                                    "badge-default")">
                                                @item.Status
                                            </span>
                                        </td>

                                                <td>
                                                    <a asp-action="Edit"
                                                       asp-route-Allocation_Id="@item.Allocation_Id"
                                                       class="btn btn-warning btn-sm">✏️</a>

                                                    <form asp-action="Delete" method="post" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="Allocation_Id" value="@item.Allocation_Id" />
                                                        <button type="submit"
                                                                class="btn btn-danger btn-sm"
                                                                onclick="return confirm('Delete this record?');">
                                                            🗑
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="7">No records found</td>
                                        </tr>
                                    }
                                </tbody>

                            </table>

                        </div>

                    </div>
                </div>
            </div>

        </div>
    </section>

</main>

@section Scripts {
    <script>
        function enableTableSearch(inputId, tableId) {
            const input = document.getElementById(inputId);
            const rows = document.querySelectorAll(`#${tableId} tbody tr`);

            input.addEventListener("input", function () {
                const filter = this.value.toLowerCase();

                rows.forEach(row => {
                    const text = row.innerText.toLowerCase();
                    row.style.display = text.includes(filter) ? "" : "none";
                });
            });
        }

        enableTableSearch("roomSearch", "roomTable");
    </script>
}