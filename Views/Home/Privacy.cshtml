@{
    ViewData["Title"] = "Privacy Policy";
}



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Avadh Prime ID Card</title>
    <style>
        /* import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap'); */

        body {
            background-color: #f0f0f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Montserrat', sans-serif;
        }

        .card {
            width: 320px;
            height: 520px;
            background: linear-gradient(180deg, #5b1f17 0%, #3a110a 100%);
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);
            position: relative;
            overflow: hidden;
        }

        /* Top White Header Section */
        .card-header {
            background-color: #ffffff;
            height: 120px;
            text-align: center;
            padding-top: 25px;
            box-sizing: border-box;
            border-radius: 16px 16px 0 0;
            position: relative;
            z-index: 2;
        }

        .card-header h1 {
            margin: 0;
            color: #3b140f;
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .card-header p {
            margin: 4px 0 0 0;
            color: #794239;
            font-size: 11px;
            font-weight: 500;
        }

        /* Diagonal Background Shapes */
        .shape-container {
            position: absolute;
            top: 120px;
            left: 0;
            width: 100%;
            height: 160px;
            z-index: 1;
        }

        .shape-right {
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 100%;
            background-color: #73271d;
            clip-path: polygon(0 40%, 100% 0, 100% 100%, 0% 100%);
        }

        .shape-left {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 85%;
            background-color: #40140d;
            clip-path: polygon(0 0, 100% 20%, 0 80%);
        }

        /* Hexagon Profile Picture */
        .avatar-wrapper {
            position: absolute;
            top: 85px; /* Overlaps header and shapes */
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            width: 110px;
            height: 125px;
            background-color: #ffffff;
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .avatar-inner {
            width: 100px;
            height: 115px;
            background-color: #e0e0e0;
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
            overflow: hidden;
        }

        .avatar-inner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Card Main Body Details */
        .card-body {
            position: absolute;
            top: 220px;
            width: 100%;
            z-index: 5;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .enr-number {
            color: #ffffff;
            font-size: 18px;
            font-weight: 700;
            margin: 0;
            letter-spacing: 0.5px;
        }

        .role-divider {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 80%;
            margin: 8px 0 20px 0;
        }

        .role-divider span {
            color: #a67c75;
            font-size: 11px;
            font-weight: 400;
            margin: 0 10px;
        }

        .role-divider::before,
        .role-divider::after {
            content: '';
            flex-grow: 1;
            height: 1px;
            background-color: rgba(255, 255, 255, 0.15);
        }

        /* Details Table Layout */
        .details {
            width: 80%;
            display: flex;
            flex-direction: column;
        }

        .detail-row {
            display: flex;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 11px;
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            width: 45%;
            color: #a67c75;
            font-weight: 500;
        }

        .detail-value {
            width: 55%;
            color: #ffffff;
            font-weight: 600;
        }

        /* Footer Text */
        .card-footer {
            position: absolute;
            bottom: 25px;
            width: 100%;
            text-align: center;
            color: #a67c75;
            font-size: 10px;
            font-weight: 400;
            z-index: 5;
        }
    </style>
</head>
<body>
    <div class="container mt-4">
         <div class="row">
      
                <div class="col-md-4">
                 <div class="card">
            <div class="card-header">
                <h1>AVADH PRIME</h1>
                <p>Boy's Hostel </p>
            </div>

            <div class="shape-container">
                <div class="shape-right"></div>
                <div class="shape-left"></div>
            </div>

            <div class="avatar-wrapper">
                <div class="avatar-inner">
                    <img src="https://i.pravatar.cc/300?img=11" alt="Student Profile">
                </div>
            </div>

            <div class="card-body">
                <h2 class="enr-number">ENR2021456789</h2>

                <div class="role-divider">
                    <span>Student</span>
                </div>

                <div class="details">
                    <div class="detail-row">
                        <div class="detail-label">Email</div>
                        <div class="detail-value">rahul.patel@email.com</div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label">Phone</div>
                        <div class="detail-value">+91 9876543210</div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label">Student ID</div>
                        <div class="detail-value">STU1023456</div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label">Hostel ID</div>
                        <div class="detail-value">HOS56789</div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label">Hostel</div>
                        <div class="detail-value">AVADH PRIME</div>
                    </div>
                </div>
            </div>

            <div class="card-footer">
                KKV Hall, Rajkot, Gujarat, India
            </div>
        </div>
    </div>
        
         </div>
    </div>

</body>
</html>



