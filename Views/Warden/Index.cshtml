@model List<AVADH_PRIME_Consume.Models.WardenModel>

@{
    ViewData["Title"] = "Warden List";
}

<style>
    .hidden {
        display: none !important;
    }
    main {
        background: #f5c068;
        font-family: 'Montserrat', sans-serif;
    }

    .pagetitle {
        margin-bottom: 20px;
    }

    /* ADD BUTTON */
    .btn-circle {
        width: 45px;
        height: 45px;
        background: #5b1f17;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        font-size: 24px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        .btn-circle:hover {
            background: #73271d;
            transform: scale(1.08);
            color: white;
        }

    /* CARD GRID */
    .card-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }

    /* CARD */
    .id-card {
        width: 320px;
        height: 520px;
        background: #5b1f17;
        position: relative;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        overflow: hidden;
    }

    .headers {
        background: #3a110a;
        color: #fff;
        height: 60px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 21px;
        font-weight: 600;
    }

    .right-curve {
        position: absolute;
        top: 65px;
        right: 0;
        width: 75%;
        height: 190px;
        background: #f5c068;
        border-top-left-radius: 120px;
        border-bottom-left-radius: 120px;
    }

    .profile-container {
        position: absolute;
        top: 90px;
        left: 55%;
        transform: translateX(-50%);
        width: 140px;
        height: 140px;
        background: #fdf5e7;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 5px 12px rgba(0,0,0,0.2);
        z-index: 15;
    }

    .profile-img {
        width: 115px;
        height: 115px;
        border-radius: 50%;
        object-fit: cover;
    }

    .info-container {
        position: absolute;
        top: 280px;
        width: 100%;
        padding-left: 20px;
    }

    /* ROW FIX */
    .row {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
    }

    /* KEY */
    .key {
        width: 110px; /* adjust if needed */
        text-align: right;
        font-size: 13px;
        color: white;
        padding-right: 10px;
    }

    /* VALUE */
    .value {
        flex: 1;
        text-align: left;
        font-size: 14px;
        font-weight: 600;
        color: white;
    }

    /* ACTION BUTTONS */
    .actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-top: 20px;
    }

    .action-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        color: #f5c068;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border: none;
    }

    .view {
        background: #3a110a;
    }

    .edit {
        background: #3a110a;
    }

    .delete {
        background: #3a110a;
    }


        .action-btn:hover {
            transform: scale(1.1);
            opacity: 0.9;
        }

   

    /* BOTTOM DESIGN */

    .bottom-left-dark {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 55%;
        height: 55px;
        background: #3a110a;
        border-top-right-radius: 60px;
    }

    .bottom-right-light {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 75%;
        height: 35px;
        background: #f5c068;
        border-top-left-radius: 50px;
    }

    .dashboard-header h1 {
        color: #5b1f17;
    }

    .dashboard-header .breadcrumb-item,
    .dashboard-header .breadcrumb-item a {
        color: #5b1f17;
    }

        .dashboard-header .breadcrumb-item.active {
            color: #5b1f17;
        }

    #studentSearch {
        border: 1px solid #5b1f17;
    }

        #studentSearch:focus {
            border-color: #5b1f17;
            box-shadow: 0 0 0 0.2rem rgba(91, 31, 23, 0.25); /* soft outline glow */
            outline: none;
        }
</style>

<main id="main" class="main">
    <section class="section">

        <!-- HEADER -->
        <div class="pagetitle d-flex align-items-center justify-content-between flex-wrap gap-2">

            <!-- LEFT -->
            <div class="dashboard-header">
                <h1 class="mb-1">Dashboard</h1>
                <nav>
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#">Home</a></li>
                        <li class="breadcrumb-item active">Wardens Management</li>
                    </ol>
                </nav>
            </div>
            <!-- SEARCH -->
            <div class="flex-grow-1 px-3" style="max-width: 400px;">
                <div class="position-relative">
                    <input type="text"
                           id="wardenSearch"
                           class="form-control pe-5"
                           placeholder="Search student ID..." />

                    <span class="position-absolute top-50 end-0 translate-middle-y me-3 text-muted">
                        🔍
                    </span>
                </div>
            </div>
           

            <!-- ADD BUTTON -->
            <div>
                <a asp-action="Add" asp-controller="Warden" class="btn-circle">
                    <i class="bi bi-plus"></i>
                </a>
            </div>

        </div>

        <!-- ALERTS -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <!-- CARDS -->
        <div class="card-wrapper">

            @foreach (var item in Model)
            {
                <div class="id-card"
                     data-code="@item.Warden_Code"
                     data-phone="@item.Phone"
                     data-email="@item.Email"
                     data-status="@item.Status">

                    <div class="headers">Avadh Prime</div>
                    <div class="right-curve"></div>

                    <!-- IMAGE -->
                    <div class="profile-container">
                        <img class="profile-img"
                             src="@(string.IsNullOrEmpty(item.Warden_Image)
                                     ? "/images/no-image.png"
                                     : (item.Warden_Image.StartsWith("/")
                                         ? item.Warden_Image
                                         : "/" + item.Warden_Image))"
                         onerror="this.src='/images/no-image.png';" />
                </div>

                    <!-- DETAILS -->
                    <div class="info-container">

                        <div class="row">
                            <div class="key">Code</div>
                            <div class="value">@item.Warden_Code</div>
                        </div>

                        <div class="row">
                            <div class="key">Phone</div>
                            <div class="value">@item.Phone</div>
                        </div>

                        <div class="row">
                            <div class="key">Email</div>
                            <div class="value">@item.Email</div>
                        </div>

                        <div class="row">
                            <div class="key">Status</div>
                            <div class="value">
                                @(item.Status == "Active" ? "🟢 Active" : "🔴 Inactive")
                            </div>
                        </div>

                        <!-- ACTIONS -->
                        <div class="actions">

                            <!-- VIEW -->
                            <a asp-action="Details"
                               asp-controller="Warden"
                               asp-route-Warden_Id="@item.Warden_Id"
                               class="action-btn view">
                                <i class="bi bi-eye"></i>
                            </a>

                            <!-- EDIT -->
                            <a asp-action="Edit"
                               asp-controller="Warden"
                               asp-route-Warden_Id="@item.Warden_Id"
                               class="action-btn edit">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <!-- DELETE -->
                            <form asp-action="Delete"
                                  asp-controller="Warden"
                                  asp-route-Warden_Id="@item.Warden_Id"
                                  method="post"
                                  style="display:inline;">

                                @Html.AntiForgeryToken()

                                <button type="submit" class="action-btn delete"
                                        onclick="return confirm('Are you sure you want to delete this warden?');">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </form>

                        </div>

                    </div>

                    <div class="bottom-left-dark"></div>
                    <div class="bottom-right-light"></div>

                </div>
                        }

        </div>

    </section>
</main>


<script>
    document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("wardenSearch");
        const cards = document.querySelectorAll(".card-wrapper .id-card");

        if (!searchInput) return;

        searchInput.addEventListener("input", function () {

            const query = this.value.toLowerCase().trim();

            cards.forEach(card => {

                const data = [
                    card.dataset.code,
                    card.dataset.phone,
                    card.dataset.email,
                    card.dataset.status
                ].join(" ").toLowerCase();

                const match = data.includes(query);

                card.classList.toggle("hidden", !match);

            });

        });

    });
</script>



