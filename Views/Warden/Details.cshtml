

@model AVADH_PRIME_Consume.Models.WardenModel

<!DOCTYPE html>
<html>
<head>
    <title>Warden Profile</title>
    <link href="~/css/stylesheet.css" rel="stylesheet" />
</head>

<body>

    <main id="main" class="main">

        <!-- HEADER -->
        <div class="header-bar">
            <div class="header-title">WARDEN DETAILS</div>

            <div>
                <a asp-action="Edit"
                   asp-route-Warden_Id="@Model.Warden_Id"
                   class="btn">EDIT</a>

                <a asp-action="Index" class="btn">BACK</a>
            </div>
        </div>

        <!-- GRID -->
        <div class="main-grid">

            <!-- 1: PROFILE -->
            <div class="box student-box">
                <img src="@(string.IsNullOrEmpty(Model.Warden_Image)
                                     ? "/images/no-image.png"
                                     : Model.Warden_Image.StartsWith("/")
                                         ? Model.Warden_Image
                                         : "/" + Model.Warden_Image)"
                     class="circle-img"
                     onerror="this.src='/images/no-image.png';" />

                <div class="student-name">
                    @Model.First_Name @Model.Last_Name
                </div>

                <div class="status">
                    @(Model.IsActive ? "Active" : "Inactive")
                </div>
            </div>

            <!-- 2: BASIC -->
            <div class="box">
                <div class="title">Basic Info</div>
                <table class="kv">
                    <tr><td class="key">ID</td><td class="colon">:</td><td class="value">@Model.Warden_Id</td></tr>
                    <tr><td class="key">Code</td><td class="colon">:</td><td class="value">@Model.Warden_Code</td></tr>
                    <tr><td class="key">Gender</td><td class="colon">:</td><td class="value">@Model.Gender</td></tr>
                    <tr>
                        <td class="key">DOB</td>
                        <td class="colon">:</td>
                        <td class="value">
                            @(Model.DateOfBirth == default ? "-" : Model.DateOfBirth.ToString("dd-MM-yyyy"))
                        </td>
                    </tr>
                    <tr><td class="key">Blood</td><td class="colon">:</td><td class="value">@Model.BloodGroup</td></tr>
                </table>
            </div>

            <!-- 3: CONTACT -->
            <div class="box">
                <div class="title">Contact Info</div>
                <table class="kv">
                    <tr><td class="key">Phone</td><td class="colon">:</td><td class="value">@Model.Phone</td></tr>
                    <tr><td class="key">Email</td><td class="colon">:</td><td class="value">@Model.Email</td></tr>
                    <tr><td class="key">Emergency</td><td class="colon">:</td><td class="value">@Model.Emergency_Contact</td></tr>
                </table>
            </div>

            <!-- 4: ADDRESS -->
            <div class="box">
                <div class="title">Address</div>
                <table class="kv">
                    <tr><td class="key">Address</td><td class="colon">:</td><td class="value">@Model.Address</td></tr>
                    <tr><td class="key">City</td><td class="colon">:</td><td class="value">@Model.City</td></tr>
                    <tr><td class="key">State</td><td class="colon">:</td><td class="value">@Model.State</td></tr>
                    <tr><td class="key">Pincode</td><td class="colon">:</td><td class="value">@Model.Pincode</td></tr>
                </table>
            </div>

            <!-- 5: PROFESSIONAL -->
            <div class="box">
                <div class="title">Professional</div>
                <table class="kv">
                    <tr><td class="key">Qualification</td><td class="colon">:</td><td class="value">@Model.Qualification</td></tr>
                    <tr><td class="key">Experience</td><td class="colon">:</td><td class="value">@Model.Experience_Years Years</td></tr>
                    <tr><td class="key">Salary</td><td class="colon">:</td><td class="value">₹@Model.Salary</td></tr>
                    <tr>
                        <td class="key">Joining</td>
                        <td class="colon">:</td>
                        <td class="value">
                            @(Model.JoiningDate == default ? "-" : Model.JoiningDate.ToString("dd-MM-yyyy"))
                        </td>
                    </tr>
                </table>
            </div>

            <!-- 6: HOSTEL -->
            <div class="box">
                <div class="title">Hostel</div>
                <table class="kv">
                    <tr><td class="key">Hostel ID</td><td class="colon">:</td><td class="value">@Model.Hostel_Id</td></tr>
                </table>
            </div>

            <!-- 7: ID PROOF -->
            <div class="box id-box">
                <div>
                    <div class="title">ID Proof</div>
                    <table class="kv">
                        <tr><td class="key">Type</td><td class="colon">:</td><td class="value">@Model.ID_Proof_Type</td></tr>
                        <tr><td class="key">Number</td><td class="colon">:</td><td class="value">@Model.ID_Proof_No</td></tr>
                    </table>
                </div>

                <div class="doc-box">
                    @if (!string.IsNullOrEmpty(Model.ID_Proof_Path))
                    {
                        <img src="@Model.ID_Proof_Path"
                             onerror="this.src='/images/no-image.png';" />
                    }
                    else
                    {
                        <img src="/images/no-image.png" />
                    }
                </div>
            </div>

            <!-- 8: STATUS -->
            <div class="box">
                <div class="title">Status</div>
                <table class="kv">
                    <tr><td class="key">Active</td><td class="colon">:</td><td class="value">@((Model.IsActive) ? "Yes" : "No")</td></tr>
                    <tr><td class="key">Status</td><td class="colon">:</td><td class="value">@Model.Status</td></tr>
                </table>
            </div>

            <!-- 9: AUDIT -->
            <div class="box">
                <div class="title">Audit</div>
                <table class="kv">
                    <tr>
                        <td class="key">Created</td>
                        <td class="colon">:</td>
                        <td class="value">
                            @(Model.CreatedAt == default ? "-" : Model.CreatedAt.ToString("dd-MM-yyyy HH:mm"))
                        </td>
                    </tr>
                    <tr>
                        <td class="key">Updated</td>
                        <td class="colon">:</td>
                        <td class="value">
                            @(Model.UpdatedAt?.ToString("dd-MM-yyyy HH:mm") ?? "-")
                        </td>
                    </tr>
                </table>
            </div>

        </div>

    </main>

</body>
</html>



