@model AVADH_PRIME_Consume.Models.WardenModel

@{
    ViewData["Title"] = Model.Warden_Id == 0 ? "Add Warden" : "Edit Warden";
}

<main id="main" class="main">

    <!-- HEADER -->
    <div class="pagetitle d-flex justify-content-between align-items-center">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
    </div>

    <section class="section dashboard pt-2">

        <div class="card shadow-sm p-4">

            <form asp-action="Add" method="post" enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <!-- HIDDEN -->
                <input type="hidden" asp-for="Warden_Id" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="UpdatedAt" />
                <input type="hidden" asp-for="Warden_Image" />
                <input type="hidden" asp-for="ID_Proof_Path" />

                <!-- IMAGE -->
                <div class="text-center mb-4">
                    <img id="previewImage"
                         src="@(string.IsNullOrEmpty(Model.Warden_Image) ? "/no-image.png" : Model.Warden_Image)"
                         class="rounded-circle border"
                         style="width:120px;height:120px;object-fit:cover;"
                         onerror="this.src='/no-image.png';" />

                    <input asp-for="ImageFile"
                           type="file"
                           class="form-control mt-2"
                           accept="image/*"
                           onchange="previewFile(event)" />

                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <!-- BASIC INFO -->
                <h5>👤 Basic Info</h5>
                <div class="row">

                    <div class="col-md-3">
                        <input asp-for="Warden_Code" class="form-control mb-2" placeholder="Warden Code" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="First_Name" class="form-control mb-2" placeholder="First Name" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Last_Name" class="form-control mb-2" placeholder="Last Name" />
                    </div>

                    <div class="col-md-3">
                        <select asp-for="Gender" class="form-control mb-2">
                            <option value="">Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <input asp-for="DateOfBirth" type="date" class="form-control mb-2"
                               value="@(Model.DateOfBirth == default ? "" : Model.DateOfBirth.ToString("yyyy-MM-dd"))" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="BloodGroup" class="form-control mb-2" placeholder="Blood Group" />
                    </div>

                </div>

                <!-- CONTACT -->
                <h5 class="mt-3">📞 Contact Info</h5>
                <div class="row">

                    <div class="col-md-4">
                        <input asp-for="Phone" class="form-control mb-2" placeholder="Phone" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Email" class="form-control mb-2" placeholder="Email" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Emergency_Contact" class="form-control mb-2" placeholder="Emergency Contact" />
                    </div>

                </div>

                <!-- ADDRESS -->
                <h5 class="mt-3">🏠 Address</h5>
                <div class="row">

                    <div class="col-md-3">
                        <input asp-for="Address" class="form-control mb-2" placeholder="Address" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="City" class="form-control mb-2" placeholder="City" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="State" class="form-control mb-2" placeholder="State" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Pincode" class="form-control mb-2" placeholder="Pincode" />
                    </div>

                </div>

                <!-- PROFESSIONAL -->
                <h5 class="mt-3">🎓 Professional Info</h5>
                <div class="row">

                    <div class="col-md-3">
                        <input asp-for="Qualification" class="form-control mb-2" placeholder="Qualification" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Experience_Years" type="number" class="form-control mb-2" placeholder="Experience Years" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="JoiningDate" type="date" class="form-control mb-2"
                               value="@(Model.JoiningDate == default ? "" : Model.JoiningDate.ToString("yyyy-MM-dd"))" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Salary" class="form-control mb-2" placeholder="Salary" />
                    </div>

                </div>

                <!-- HOSTEL -->
                <h5 class="mt-3">🏢 Hostel Info</h5>
                <div class="row">
                    <div class="col-md-4">
                        <input asp-for="Hostel_Id" class="form-control mb-2" placeholder="Hostel ID" />
                    </div>
                </div>

                <!-- ID PROOF -->
                <h5 class="mt-3">🆔 ID Proof</h5>
                <div class="row">

                    <div class="col-md-4">
                        <input asp-for="ID_Proof_Type" class="form-control mb-2" placeholder="ID Type" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="ID_Proof_No" class="form-control mb-2" placeholder="ID Number" />
                    </div>

                    <div class="col-md-4">

                        <input type="file"
                               name="IDProofFile"
                               class="form-control mb-2"
                               accept="image/*"
                               onchange="previewDoc(event)" />

                        <img id="docPreview"
                             src="@(string.IsNullOrEmpty(Model.ID_Proof_Path) ? "/no-image.png" : Model.ID_Proof_Path)"
                             class="border rounded mt-2"
                             style="width:120px;height:120px;object-fit:cover;"
                             onerror="this.src='/no-image.png';" />
                    </div>

                </div>

                <!-- STATUS -->
                <h5 class="mt-3">⚙ Status</h5>
                <div class="row">

                    <div class="col-md-4">
                        <select asp-for="IsActive" class="form-control mb-2">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Status" class="form-control mb-2" placeholder="Status" />
                    </div>

                </div>

                <!-- SUBMIT -->
                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success">
                        @(Model.Warden_Id == 0 ? "➕ Add Warden" : "✏️ Update Warden")
                    </button>
                </div>

            </form>

        </div>

    </section>

</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewFile(event) {
            const reader = new FileReader();
            reader.onload = function () {
                document.getElementById('previewImage').src = reader.result;
            };
            reader.readAsDataURL(event.target.files[0]);
        }

        function previewDoc(event) {
            const reader = new FileReader();
            reader.onload = function () {
                document.getElementById('docPreview').src = reader.result;
            };
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
}




