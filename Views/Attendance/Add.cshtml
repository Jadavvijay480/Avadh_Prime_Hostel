@model AVADH_PRIME_Consume.Models.AttendanceModel

@{
    ViewData["Title"] = Model.Attendance_Id == 0 ? "Add Attendance" : "Edit Attendance";
}

<main id="main" class="main">

    <div class="pagetitle">
        <h1>@ViewData["Title"]</h1>
    </div>

    <section class="section">
        <div class="row">
            <div class="col-lg-8 mx-auto">

                <div class="card">
                    <div class="card-body pt-4">

                        <form asp-action="Add" method="post">

                            @Html.AntiForgeryToken()

                            <!-- Hidden ID -->
                            <input type="hidden" asp-for="Attendance_Id" />

                            <!-- Student ID -->
                            <div class="mb-3">
                                <label class="form-label">Student ID</label>
                                <input asp-for="Student_Id" class="form-control" />
                                <span asp-validation-for="Student_Id" class="text-danger"></span>
                            </div>

                            <!-- Date -->
                            <div class="mb-3">
                                <label class="form-label">Attendance Date</label>
                                <input asp-for="Attendance_Date" type="date" class="form-control" />
                            </div>

                            <!-- Status -->
                            <div class="mb-3">
                                <label class="form-label">Status</label>
                                <select asp-for="Status" class="form-control">
                                    <option>Present</option>
                                    <option>Absent</option>
                                    <option>Leave</option>
                                </select>
                            </div>

                            <!-- Check In -->
                            <div class="mb-3">
                                <label class="form-label">Check-In Time</label>
                                <input asp-for="CheckIn_Time" type="time" class="form-control" />
                            </div>

                            <!-- Check Out -->
                            <div class="mb-3">
                                <label class="form-label">Check-Out Time</label>
                                <input asp-for="CheckOut_Time" type="time" class="form-control" />
                            </div>

                            <!-- Remarks -->
                            <div class="mb-3">
                                <label class="form-label">Remarks</label>
                                <textarea asp-for="Remarks" class="form-control"></textarea>
                            </div>

                            <!-- Marked By -->
                            <div class="mb-3">
                                <label class="form-label">Marked By</label>
                                <input asp-for="Marked_By" class="form-control" />
                            </div>

                            <!-- CreatedAt -->
                            <input type="hidden" asp-for="CreatedAt" value="@DateTime.Now" />

                            <!-- UpdatedAt -->
                            @if (Model.Attendance_Id != 0)
                            {
                                <input type="hidden" asp-for="UpdatedAt" value="@DateTime.Now" />
                            }

                            <!-- Buttons -->
                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-success">
                                    @(Model.Attendance_Id == 0 ? "Save" : "Update")
                                </button>

                                <a asp-action="Index" class="btn btn-secondary ms-2">
                                    Cancel
                                </a>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>
    </section>

</main>