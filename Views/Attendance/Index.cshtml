@model List<AVADH_PRIME_Consume.Models.AttendanceModel>

@{
    ViewData["Title"] = "Attendance List";
}

<style>
    /* PRESENT → GREEN */
    .badge-present {
        background-color: #28a745;
        color: #fff;
    }

    /* ABSENT → RED */
    .badge-absent {
        background-color: #dc3545;
        color: #fff;
    }

    /* LEAVE → BLUE */
    .badge-leave {
        background-color: #007bff;
        color: #fff;
    }

    /* LATE → ORANGE */
    .badge-late {
        background-color: #fd7e14;
        color: #fff;
    }

    /* DEFAULT */
    .badge-default {
        background-color: #6c757d;
        color: #fff;
    }

    #attendanceTable thead th {
        color: #5b1f17 !important;
    }

    /* TABLE CARD */
    .card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 6px 18px rgba(0,0,0,0.15);
        overflow: hidden;
    }

    /* TABLE HEADER */
    #attendanceTable thead {
        background: linear-gradient(45deg, #5b1f17, #73271d);
    }

        #attendanceTable thead th {
            color: #fff;
            font-weight: 600;
            font-size: 14px;
            padding: 14px;
            border: none;
            text-transform: uppercase;
            letter-spacing: 0.5px;
          
        }

    /* TABLE BODY */
    #attendanceTable tbody tr {
        background-color: #fffaf5;
        transition: all 0.2s ease;
    }

        /* STRIPED ROWS */
        #attendanceTable tbody tr:nth-child(even) {
            background-color: #fde8d7;
        }

        /* HOVER EFFECT */
        #attendanceTable tbody tr:hover {
            background-color: #f8d7c4;
            transform: scale(1.002);
        }

    /* TABLE CELLS */
    #attendanceTable td {
        padding: 12px;
        font-size: 13px;
        color: #333;
        border-bottom: 1px solid #f1d2b8;
    }

    /* BADGES (STATUS) */
    .badge.bg-success {
        background-color: #28a745 !important;
        font-size: 12px;
        padding: 6px 10px;
    }

    .badge.bg-danger {
        background-color: #dc3545 !important;
        font-size: 12px;
        padding: 6px 10px;
    }

    /* ACTION BUTTONS */
    .btn-warning {
        background-color: #f5c068;
        border: none;
        color: #5b1f17;
        font-weight: 500;
    }

        .btn-warning:hover {
            background-color: #e0a94f;
        }

    .btn-danger {
        background-color: #5b1f17;
        border: none;
    }

        .btn-danger:hover {
            background-color: #73271d;
        }

    /* EMPTY DATA ROW */
    tbody tr td[colspan] {
        text-align: center;
        font-weight: 500;
        color: #5b1f17;
        padding: 20px;
    }





    .main{
        background-color: #f5c068;
    }

    .btn-circle {
        width: 45px;
        height: 45px;
        background: #5b1f17;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        font-size: 24px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        .btn-circle:hover {
            background: #73271d;
            transform: scale(1.08);
            color: white;
        }
    .dashboard-header h1 {
        color: #5b1f17;
    }

    .dashboard-header .breadcrumb-item,
    .dashboard-header .breadcrumb-item a {
        color: #5b1f17;
    }

        .dashboard-header .breadcrumb-item.active {
            color: #5b1f17;
        }

    #studentSearch {
        border: 1px solid #5b1f17;
    }

        #studentSearch:focus {
            border-color: #5b1f17;
            box-shadow: 0 0 0 0.2rem rgba(91, 31, 23, 0.25); /* soft outline glow */
            outline: none;
        }
   
</style>


<main id="main" class="main">

 
    <!-- HEADER -->
    <div class="pagetitle d-flex align-items-center justify-content-between flex-wrap gap-2">

        <!-- LEFT -->
        <div>
            <h1 class="mb-1" style="color:#5b1f17;">Dashboard</h1>
            <nav>
                <ol class="breadcrumb mb-0" style="color:#5b1f17;">
                    <li class="breadcrumb-item">
                        <a href="index.html" style="color:#5b1f17;">Home</a>
                    </li>
                    <li class="breadcrumb-item active" style="color:#5b1f17;">
                        📅 Attendance Management
                    </li>
                </ol>
            </nav>
        </div>
       

       

        <!-- SEARCH -->
        <div class="flex-grow-1 px-3" style="max-width: 400px;">
            <div class="position-relative">
                <input type="text"
                       id="attendanceSearch"
                       class="form-control pe-5"
                       placeholder="Search student ID..." />

                <span class="position-absolute top-50 end-0 translate-middle-y me-3 text-muted">
                    🔍
                </span>
            </div>
        </div>

        <!-- ADD BUTTON -->
        <div>
            <a asp-action="Add" class="btn-circle">
                +
            </a>
        </div>
    </div>


    <!-- BODY -->
    <section class="section dashboard">
        <div class="row">

            <!-- ALERTS -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <!-- TABLE -->
            <div class="col-12">
                <div class="card">

                    <div class="card-body pt-3">

                        <div class="table-responsive">

                            <table class="table table-hover align-middle text-center" id="attendanceTable">

                                <thead >
                                    <tr>
                                        <th>ID</th>
                                        <th>Student</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Check-In</th>
                                        <th>Check-Out</th>
                                        <th>Remarks</th>
                                        <th>Marked By</th>
                                        <th>Created</th>
                                        <th>Updated</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr class="attendance-row"
                                                data-student="@item.Student_Id"
                                                data-date="@item.Attendance_Date.ToString("yyyy-MM-dd")"
                                                data-status="@item.Status">

                                                <td>@item.Attendance_Id</td>

                                                <td>@item.Student_Id</td>

                                                <td>@item.Attendance_Date.ToString("dd-MM-yyyy")</td>

                                                <td>
                                                    <span class="badge
                                                                  @(item.Status == "Present" ? "badge-present" :
                                                                    item.Status == "Absent" ? "badge-absent" :
                                                                    item.Status == "Leave" ? "badge-leave" :
                                                                    item.Status == "Late" ? "badge-late" :
                                                                    "badge-default")">
                                                                   @item.Status
                                                     </span>
                                                </td>

                                                <td>@(item.CheckIn_Time?.ToString(@"hh\:mm") ?? "-")</td>

                                                <td>@(item.CheckOut_Time?.ToString(@"hh\:mm") ?? "-")</td>

                                                <td>@(item.Remarks ?? "-")</td>

                                                <td>@(item.Marked_By ?? 0)</td>

                                                <td>@item.CreatedAt.ToString("dd-MM-yyyy HH:mm")</td>

                                                <td>@(item.UpdatedAt?.ToString("dd-MM-yyyy HH:mm") ?? "-")</td>

                                                <td>
                                                    <a asp-action="Edit"
                                                       asp-route-Attendance_Id="@item.Attendance_Id"
                                                       class="btn btn-warning btn-sm">✏️</a>

                                                    <form asp-action="Delete" method="post" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="Attendance_Id" value="@item.Attendance_Id" />
                                                        <button type="submit"
                                                                class="btn btn-danger btn-sm"
                                                                onclick="return confirm('Delete this record?');">
                                                            🗑
                                                        </button>
                                                    </form>
                                                </td>

                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="11">No attendance records found</td>
                                        </tr>
                                    }
                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>
            </div>

        </div>
    </section>

</main>

@section Scripts {
    <script>
        function enableTableSearch(inputId, tableId) {

            const input = document.getElementById(inputId);
            const rows = document.querySelectorAll(`#${tableId} tbody tr`);

            if (!input) return;

            input.addEventListener("input", function () {

                const filter = this.value.toLowerCase().trim();

                rows.forEach(row => {

                    const text = row.innerText.toLowerCase();

                    // RESET CASE (important)
                    if (filter === "") {
                        row.style.display = "";
                        return;
                    }

                    row.style.display = text.includes(filter) ? "" : "none";

                });

            });
        }

        // ✅ ONLY CALL WHAT EXISTS ON THIS PAGE
        enableTableSearch("attendanceSearch", "attendanceTable");
    </script>
}

