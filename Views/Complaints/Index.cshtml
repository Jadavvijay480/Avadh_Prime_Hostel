@model List<AVADH_PRIME_Consume.Models.ComplaintsModel>

@{
    ViewData["Title"] = "Complaint List";
}

<style>
    .hidden {
        display: none !important;
    }
    main {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f5c068;
    }
    

    .id-card {
        width: 100%;
        max-width: 320px;
        height: 580px;
        background-color: #fff;
        border-radius: 35px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        position: relative;
    }

    .top-section {
        height: 40%;
        position: relative;
        overflow: hidden;
        border-bottom-left-radius: 70px;
    }

        .top-section img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .company-name {
        position: absolute;
        top: 12px;
        left: 50%;
        transform: translateX(-50%);
        color: #fff;
        font-size: 20px;
        font-weight: bold;
    }

    .bottom-section {
        background-color: #5b1f17;
        height: 60%;
        color: white;
        padding-top: 70px;
        border-top-right-radius: 70px;
        text-align: center;
    }

    .info-container {
        margin-top: 10px;
        padding: 0 15px;
    }

    /* ROW */
    .row-info {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
    }

    /* KEY */
    .key {
        width: 120px; /* fixed width */
        text-align: right;
        font-size: 12px;
        color: #ccc;
        padding-right: 10px;
    }

    /* VALUE */
    .value {
        flex: 1;
        text-align: left;
        font-size: 13px;
        font-weight: 600;
    }
    /* .row-info {
        display: grid;
        grid-template-columns: 45% 55%;
        margin-bottom: 6px;
    }

    .key {
        text-align: right;
        font-size: 12px;
        color: #ccc;
    }

    .value {
        text-align: left;
        font-size: 13px;
        font-weight: 600;
        padding-left: 8px;
    } */

    .actions {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 30px;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        color: #5b1f17;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
    }

    .view {
        background: #f5c068;
    }

    .edit {
        background: #f5c068;
    }

    .delete {
        background: #f5c068;
    }

    .btn-circle {
        width: 45px;
        height: 45px;
        background: #5b1f17;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        font-size: 24px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        .btn-circle:hover {
            transform: scale(1.1);
            background: #000;
        }

    .dashboard-header h1 {
        color: #5b1f17;
    }

    .dashboard-header .breadcrumb-item,
    .dashboard-header .breadcrumb-item a {
        color: #5b1f17;
    }

        .dashboard-header .breadcrumb-item.active {
            color: #5b1f17;
        }

    #complaintSearch {
        border: 1px solid #5b1f17;
    }

        #complaintSearch:focus {
            border-color: #5b1f17;
            box-shadow: 0 0 0 0.2rem rgba(91, 31, 23, 0.25);
            outline: none;
        }
</style>

<main id="main" class="main">

    <!-- HEADER -->
    <div class="pagetitle d-flex align-items-center justify-content-between flex-wrap gap-2">

        <!-- LEFT -->
        <div class="dashboard-header">
            <h1 class="mb-1">Dashboard</h1>
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active">🛠 Complaint Management</li>
                </ol>
            </nav>
        </div>

       

        <div class="flex-grow-1 px-3" style="max-width: 400px;">
            <input type="text" id="complaintSearch" class="form-control" placeholder="Search Student ID..." />
        </div>

        <div>
            <a asp-action="Add" class="btn-circle">
                +
            </a>
        </div>

    </div>

    <!-- CONTENT -->
    <section class="section dashboard">
        <div class="row g-4 justify-content-center">

            @foreach (var c in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 d-flex justify-content-center complaint-item">

                    <div class="id-card"
                         data-student="@c.Student_Id"
                         data-type="@c.Complaint_Type"
                         data-status="@c.Status"
                         data-date="@c.Complaint_Date.ToString("dd-MM-yyyy")"
                         data-resolved="@(c.Resolved_Date.HasValue? c.Resolved_Date.Value.ToString("dd-MM-yyyy") : "")"
                         data-rating="@(c.Rating ?? 0)">

                       
                        <!-- TOP -->
                        <div class="top-section">

                            @{
                                var filePath = c.Attachment_Path;
                                var ext = filePath != null ? System.IO.Path.GetExtension(filePath).ToLower() : "";
                            }

                            @if (!string.IsNullOrEmpty(filePath) && (ext == ".jpg" || ext == ".png" || ext == ".jpeg"))
                            {
                                <img src="@filePath"
                                     alt="Complaint Image"
                                     onerror="this.src='/images/no-image.png';" />
                            }
                            else
                            {
                                <img src="/images/no-image.png" alt="No Image" />
                            }

                        <div class="company-name">Avadh Prime</div>

                    </div>

                        <!-- BOTTOM -->
                        <div class="bottom-section">

                            <div class="info-container">

                                <div class="row-info">
                                    <div class="key">Student ID :</div>
                                    <div class="value">@c.Student_Id</div>
                                </div>

                                <div class="row-info">
                                    <div class="key">Type :</div>
                                    <div class="value">@c.Complaint_Type</div>
                                </div>

                                <div class="row-info">
                                    <div class="key">Status :</div>
                                    <div class="value">
                                        @(c.Status == "Resolved" ? "🟢 Resolved" : "🔴 Pending")
                                    </div>
                                </div>

                                <div class="row-info">
                                    <div class="key">Complaint :</div>
                                    <div class="value">
                                        @c.Complaint_Date.ToString("dd-MM-yyyy")
                                    </div>
                                </div>

                                <div class="row-info">
                                    <div class="key">Resolved :</div>
                                    <div class="value">
                                        @(c.Resolved_Date.HasValue
                                                                            ? c.Resolved_Date.Value.ToString("dd-MM-yyyy")
                                                                            : "-")
                                </div>
                            </div>

                                <div class="row-info">
                                    <div class="key">Rating :</div>
                                    <div class="value">
                                        @(c.Rating.HasValue? c.Rating + " ⭐" : "-")
                                    </div>
                                </div>

                                <!-- ACTIONS -->
                                <div class="actions">

                                    <a asp-action="Details"
                                       asp-route-Complaint_Id="@c.Complaint_Id"
                                       class="action-btn view">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-Complaint_Id="@c.Complaint_Id"
                                       class="action-btn edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form asp-action="Delete" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Complaint_Id" value="@c.Complaint_Id" />

                                        <button type="submit"
                                                class="action-btn delete"
                                                onclick="return confirm('Delete complaint?');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>
                        }

        </div>
    </section>

</main>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("complaintSearch");
        const cards = document.querySelectorAll(".complaint-item");

        searchInput.addEventListener("input", function () {

            const query = this.value.toLowerCase().trim();

            cards.forEach(item => {

                const card = item.querySelector(".id-card");
                const studentId = (card.dataset.student || "").toLowerCase();

                const match = studentId.includes(query);

                item.classList.toggle("hidden", !match);

            });

        });

    });
</script>