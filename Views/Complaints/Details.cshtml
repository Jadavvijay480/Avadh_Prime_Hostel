@model AVADH_PRIME_Consume.Models.ComplaintsModel

<!DOCTYPE html>
<html>
<head>
    <title>Complaint Profile</title>

    @* <link href="~/css/stylesheet.css" rel="stylesheet" /> *@
    <link href="~/css/stylesheet.css" rel="stylesheet" />
 
</head>

<body>

    <main id="main" class="main">

        <!-- HEADER -->
        <div class="header-bar">
            <div class="header-title">COMPLAINT DETAILS</div>

            <div>
                <a asp-action="Edit"
                   asp-route-Complaint_Id="@Model.Complaint_Id"
                   class="btn">EDIT</a>

                <a asp-action="Index" class="btn">BACK</a>
            </div>
        </div>

        <!-- GRID -->
        <div class="main-grid">

            <!-- ATTACHMENT -->
            <div class="box student-box">
                @{
                    var filePath = Model.Attachment_Path;
                    var ext = filePath != null ? System.IO.Path.GetExtension(filePath).ToLower() : "";
                }

                @if (!string.IsNullOrEmpty(filePath) && (ext == ".jpg" || ext == ".png" || ext == ".jpeg"))
                {
                    <img src="@Url.Content("~" + filePath)"
                         class="circle-img"
                         onerror="this.src='/images/no-image.png';" />
                }
                else
                {
                    <img src="/images/no-image.png" class="circle-img" />
                }

                <div>Complaints Image</div>
            </div>

            <!-- BASIC -->
            <div class="box">
                <div class="title">Basic Info</div>
                <table class="kv">
                    <tr><td class="key">ID</td><td class="colon">:</td><td class="value">@Model.Complaint_Id</td></tr>
                    <tr><td class="key">Student</td><td class="colon">:</td><td class="value">@Model.Student_Id</td></tr>
                    <tr><td class="key">Title</td><td class="colon">:</td><td class="value">@Model.Complaint_Title</td></tr>
                    <tr><td class="key">Type</td><td class="colon">:</td><td class="value">@Model.Complaint_Type</td></tr>
                </table>
            </div>

            <!-- STATUS -->
            <div class="box">
                <div class="title">Status Info</div>
                <table class="kv">
                    <tr><td class="key">Priority</td><td class="colon">:</td><td class="value">@Model.Priority</td></tr>
                    <tr><td class="key">Status</td><td class="colon">:</td><td class="value status">@Model.Status</td></tr>
                    <tr><td class="key">Assigned</td><td class="colon">:</td><td class="value">@(Model.Assigned_To ?? 0)</td></tr>
                </table>
            </div>

           

            <!-- DESCRIPTION -->
            @* <div class="box">
                <div class="title">Description</div>
                <p>@Model.Complaint_Description</p>
            </div> *@
            <div class="box">
                <div class="title with-line">Description</div>
                <p>@Model.Complaint_Description</p>
            </div>

            <!-- DATE -->
            <div class="box">
                <div class="title">Date Info</div>
                <table class="kv">
                    <tr><td class="key">Complaint</td><td class="colon">:</td><td class="value">@Model.Complaint_Date.ToString("dd-MM-yyyy")</td></tr>
                    <tr><td class="key">Resolved</td><td class="colon">:</td><td class="value">@(Model.Resolved_Date?.ToString("dd-MM-yyyy") ?? "-")</td></tr>
                </table>
            </div>

            <!-- RESOLUTION -->
            <div class="box">
                <div class="title">Resolution</div>
                <p>@(Model.Resolution_Remarks ?? "-")</p>
            </div>

            <!-- FEEDBACK -->
            <div class="box">
                <div class="title">Feedback</div>
                <table class="kv">
                    <tr><td class="key">Feedback</td><td class="colon">:</td><td class="value">@(Model.Feedback ?? "-")</td></tr>
                    <tr><td class="key">Rating</td><td class="colon">:</td><td class="value">@(Model.Rating ?? 0)/5 ⭐</td></tr>
                </table>
            </div>

            <!-- AUDIT -->
            <div class="box">
                <div class="title">Audit</div>
                <table class="kv">
                    <tr><td class="key">Created</td><td class="colon">:</td><td class="value">@Model.CreatedAt.ToString("dd-MM-yyyy")</td></tr>
                    <tr><td class="key">Updated</td><td class="colon">:</td><td class="value">@(Model.UpdatedAt?.ToString("dd-MM-yyyy") ?? "-")</td></tr>
                </table>
            </div>

        </div>

    </main>

</body>
</html>

