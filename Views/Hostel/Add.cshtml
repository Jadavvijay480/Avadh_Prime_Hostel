@model AVADH_PRIME_Consume.Models.HostelModel

@{
    ViewData["Title"] = Model.Hostel_Id == 0 ? "Add Hostel" : "Edit Hostel";
}

<main id="main" class="main">

    <!-- HEADER -->
    <div class="pagetitle d-flex justify-content-between align-items-center">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
    </div>

    <section class="section dashboard pt-2">

        <div class="card shadow-sm p-4">

            <form asp-action="Add" method="post">

                @Html.AntiForgeryToken()

                <!-- HIDDEN -->
                <input type="hidden" asp-for="Hostel_Id" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="UpdatedAt" />

                <!-- BASIC INFO -->
                <h5 class="mb-3">🏠 Basic Information</h5>
                <div class="row">

                    <div class="col-md-4">
                        <input asp-for="Hostel_Name" class="form-control mb-2" placeholder="Hostel Name" />
                    </div>

                    <div class="col-md-4">
                        <select asp-for="Hostel_Type" class="form-control mb-2">
                            <option value="">Select Type</option>
                            <option>Boys</option>
                            <option>Girls</option>
                            <option>Co-ed</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <select asp-for="IsActive" class="form-control mb-2">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>

                </div>

                <!-- CAPACITY -->
                <h5 class="mt-3 mb-3">🛏 Capacity Details</h5>
                <div class="row">

                    <div class="col-md-6">
                        <input asp-for="Total_Rooms" type="number" class="form-control mb-2" placeholder="Total Rooms" />
                    </div>

                    <div class="col-md-6">
                        <input asp-for="Total_Beds" type="number" class="form-control mb-2" placeholder="Total Beds" />
                    </div>

                </div>

                <!-- LOCATION -->
                <h5 class="mt-3 mb-3">📍 Location</h5>
                <div class="row">

                    <div class="col-md-6">
                        <input asp-for="Address" class="form-control mb-2" placeholder="Address" />
                    </div>

                    <div class="col-md-6">
                        <input asp-for="City" class="form-control mb-2" placeholder="City" />
                    </div>

                    <div class="col-md-6">
                        <input asp-for="State" class="form-control mb-2" placeholder="State" />
                    </div>

                    <div class="col-md-6">
                        <input asp-for="Pincode" class="form-control mb-2" placeholder="Pincode" />
                    </div>

                </div>

                <!-- CONTACT -->
                <h5 class="mt-3 mb-3">📞 Contact Info</h5>
                <div class="row">

                    <div class="col-md-6">
                        <input asp-for="Contact_No" class="form-control mb-2" placeholder="Contact Number" />
                    </div>

                    <div class="col-md-6">
                        <input asp-for="Email" class="form-control mb-2" placeholder="Email" />
                    </div>

                </div>

                <!-- FEES -->
                <h5 class="mt-3 mb-3">💰 Fee Details</h5>
                <div class="row">

                    <div class="col-md-6">
                        <input asp-for="Monthly_Rent" type="number" step="0.01" class="form-control mb-2" placeholder="Monthly Rent" />
                    </div>

                    <div class="col-md-6">
                        <input asp-for="Security_Deposit" type="number" step="0.01" class="form-control mb-2" placeholder="Security Deposit" />
                    </div>

                </div>

                <!-- SUBMIT -->
                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success">
                        @(Model.Hostel_Id == 0 ? "➕ Add Hostel" : "✏️ Update Hostel")
                    </button>
                </div>

            </form>

        </div>

    </section>

</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}