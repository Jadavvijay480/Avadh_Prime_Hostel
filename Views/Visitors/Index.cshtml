<main id="main" class="main">

    <!-- HEADER -->
    <div class="pagetitle d-flex justify-content-between align-items-center flex-wrap gap-2">

        <!-- LEFT -->
        <div class="dashboard-header">
            <h1 class="mb-1">Dashboard</h1>
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active"> Visitors Management</li>
                </ol>
            </nav>
        </div>
        <!-- SEARCH -->
        <div class="flex-grow-1 px-3" style="max-width: 400px;">
            <div class="position-relative">
                <input type="text"
                       id="visitorSearch"
                       class="form-control pe-5"
                       placeholder="Search student ID..." />

                <span class="position-absolute top-50 end-0 translate-middle-y me-3 text-muted">
                    🔍
                </span>
            </div>
        </div>

       

        <div>
            <a asp-action="Add" asp-controller="Visitors" class="btn-circle">+</a>
        </div>

    </div>

    <!-- CARDS -->
    <div class="card-wrapper">

        @foreach (var v in Model)
        {
            <div class="id-card"
                 data-name="@($"{v.First_Name} {v.Last_Name}")"
                 data-phone="@v.Phone"
                 data-date="@v.Visit_Date.ToString("dd-MM-yyyy")"
                 data-in="@v.Check_In_Time.ToString("HH:mm")"
                 data-out="@(v.Check_Out_Time.HasValue? v.Check_Out_Time.Value.ToString("HH:mm") : "-")"
                 data-status="@(v.Check_Out_Time == null ? "Inside" : "Exited")">

                <div class="headers">Avadh Prime</div>
                <div class="right-curve"></div>

                <!-- IMAGE -->
                <div class="profile-container">
                    <img class="profile-img"
                         src="~/assets/img/warden.png"
                         onerror="this.src='/images/no-image.png';" />
                </div>

                <!-- DETAILS -->
                <div class="info-container">

                    <div class="row">
                        <div class="key">Name</div>
                        <div class="value">@v.First_Name @v.Last_Name</div>
                    </div>

                    <div class="row">
                        <div class="key">Phone</div>
                        <div class="value">@v.Phone</div>
                    </div>

                    <div class="row">
                        <div class="key">Date</div>
                        <div class="value">@v.Visit_Date.ToString("dd-MM-yyyy")</div>
                    </div>

                    <div class="row">
                        <div class="key">In</div>
                        <div class="value">@v.Check_In_Time.ToString("HH:mm")</div>
                    </div>

                    <div class="row">
                        <div class="key">Out</div>
                        <div class="value">
                            @(v.Check_Out_Time.HasValue? v.Check_Out_Time.Value.ToString("HH:mm") : "-")
                        </div>
                    </div>

                    <div class="row">
                        <div class="key">Status</div>
                        <div class="value">
                            @(v.Check_Out_Time == null ? "🟢 Inside" : "🔴 Exited")
                        </div>
                    </div>

                    <!-- ACTIONS -->
                    <div class="actions">

                        <a asp-action="Details"
                           asp-controller="Visitors"
                           asp-route-Visitor_Id="@v.Visitor_Id"
                           class="action-btn view">
                            <i class="bi bi-eye"></i>
                        </a>

                        <a asp-action="Edit"
                           asp-controller="Visitors"
                           asp-route-Visitor_Id="@v.Visitor_Id"
                           class="action-btn edit">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <form asp-action="Delete"
                              asp-controller="Visitors"
                              asp-route-Visitor_Id="@v.Visitor_Id"
                              method="post">

                            @Html.AntiForgeryToken()

                            <button type="submit" class="action-btn delete"
                                    onclick="return confirm('Delete visitor?');">
                                <i class="bi bi-trash"></i>
                            </button>

                        </form>

                    </div>

                </div>

                <div class="bottom-left-dark"></div>
                <div class="bottom-right-light"></div>

            </div>
        }

    </div>

</main>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("visitorSearch");
        const cards = document.querySelectorAll(".card-wrapper .id-card");

        if (!searchInput) return;

        searchInput.addEventListener("input", function () {

            const query = this.value.toLowerCase().trim();

            cards.forEach(card => {

                const data = [
                    card.dataset.name,
                    card.dataset.phone,
                    card.dataset.date,
                    card.dataset.in,
                    card.dataset.out,
                    card.dataset.status
                ].join(" ").toLowerCase();

                const match = data.includes(query);

                // ✅ SAFE METHOD (recommended)
                card.classList.toggle("hidden", !match);

            });

        });

    });
</script>

