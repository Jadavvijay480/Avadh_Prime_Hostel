@model List<AVADH_PRIME_Consume.Models.VisitorsModel>

@{
    ViewData["Title"] = "Visitors List";
}
<style>
    .hidden {
        display: none !important;
    }

    main {
        background: #f5c068;
        font-family: 'Montserrat', sans-serif;
    }

    /* ADD BUTTON */
    .btn-circle {
        width: 45px;
        height: 45px;
        background: #5b1f17;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        font-size: 24px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        .btn-circle:hover {
            background: #73271d;
            transform: scale(1.08);
            color: white;
        }

    /* CARD GRID */
    .card-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }

    /* CARD */
    .id-card {
        width: 320px;
        height: 520px;
        background: #5b1f17;
        position: relative;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        overflow: hidden;
    }

    .headers {
        background: #3a110a;
        color: #fff;
        height: 60px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 21px;
        font-weight: 600;
    }

    .right-curve {
        position: absolute;
        top: 65px;
        right: 0;
        width: 75%;
        height: 190px;
        background: #f5c068;
        border-top-left-radius: 120px;
        border-bottom-left-radius: 120px;
    }

    .profile-container {
        position: absolute;
        top: 90px;
        left: 55%;
        transform: translateX(-50%);
        width: 140px;
        height: 140px;
        background: #fdf5e7;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 5px 12px rgba(0,0,0,0.2);
        z-index: 15;
    }

    .profile-img {
        width: 115px;
        height: 115px;
        border-radius: 50%;
        object-fit: cover;
    }

    /* CENTER BLOCK ONLY */
    .info-container {
        position: absolute;
        top: 260px;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center; /* ✅ center whole block */
    }

    /* ROW */
    .row {
        display: flex;
        justify-content: flex-start; /* ❌ remove center */
        align-items: center;
        margin-bottom: 6px;
        width: 220px; /* ✅ fixed width for alignment */
    }

    /* KEY */
    .key {
        width: 90px;
        text-align: right;
        font-size: 12px;
        color: white;
        padding-right: 10px;
    }

    /* VALUE */
    .value {
        width: 130px;
        text-align: left;
        font-size: 13px;
        font-weight: 600;
        color: white;
    }

    /* ACTION BUTTONS */
    .actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-top: 15px;
    }

    .action-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        color: #f5c068;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border: none;
        background: #3a110a;
    }

        .action-btn:hover {
            transform: scale(1.1);
            opacity: 0.9;
        }

    /* BOTTOM DESIGN */
    .bottom-left-dark {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 55%;
        height: 55px;
        background: #3a110a;
        border-top-right-radius: 60px;
    }

    .bottom-right-light {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 75%;
        height: 35px;
        background: #f5c068;
        border-top-left-radius: 50px;
    }

    /* HEADER TEXT */
    .dashboard-header h1,
    .dashboard-header .breadcrumb-item,
    .dashboard-header .breadcrumb-item a,
    .dashboard-header .breadcrumb-item.active {
        color: #5b1f17;
    }

    /* SEARCH */
    #visitorSearch {
        border: 1px solid #5b1f17;
    }

        #visitorSearch:focus {
            border-color: #5b1f17;
            box-shadow: 0 0 0 0.2rem rgba(91, 31, 23, 0.25);
            outline: none;
        }
</style>
