@model AVADH_PRIME_Consume.Models.VisitorsModel

@{
    ViewData["Title"] = Model.Visitor_Id == 0 ? "Add Visitor" : "Edit Visitor";
}

<main id="main" class="main">

    <!-- HEADER -->
    <div class="pagetitle d-flex justify-content-between align-items-center">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
    </div>

    <section class="section dashboard pt-2">

        <div class="card shadow-sm p-4">

            <!-- IMPORTANT: SAME ACTION FOR ADD + EDIT -->
            <form asp-action="Add" asp-controller="Visitors" method="post" >

                @Html.AntiForgeryToken()

                <!-- HIDDEN FIELDS (CRITICAL FOR EDIT) -->
                <input type="hidden" asp-for="Visitor_Id" />
                <input type="hidden" asp-for="Created_At" />
                <input type="hidden" asp-for="Created_By" />

                <!-- PERSONAL INFO -->
                <h5 class="mb-3">👤 Personal Info</h5>

                <div class="row">

                    <div class="col-md-4">
                        <input asp-for="First_Name" class="form-control mb-2" placeholder="First Name" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Last_Name" class="form-control mb-2" placeholder="Last Name" />
                    </div>

                    <div class="col-md-4">
                        <select asp-for="Gender" class="form-control mb-2">
                            <option value="">Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Phone" class="form-control mb-2" placeholder="Phone" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Email" class="form-control mb-2" placeholder="Email" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Country" class="form-control mb-2" placeholder="Country" />
                    </div>

                </div>

                <!-- ID PROOF -->
                <h5 class="mt-3 mb-3">🆔 ID Proof</h5>

                <div class="row">

                    <div class="col-md-6">
                        <input asp-for="Id_Proof_Type" class="form-control mb-2" placeholder="ID Type" />
                    </div>

                    <div class="col-md-6">
                        <input asp-for="Id_Proof_Number" class="form-control mb-2" placeholder="ID Number" />
                    </div>

                </div>

                <!-- ADDRESS -->
                <h5 class="mt-3 mb-3">📍 Address</h5>

                <div class="row">

                    <div class="col-md-4">
                        <input asp-for="Address" class="form-control mb-2" placeholder="Address" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="City" class="form-control mb-2" placeholder="City" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="State" class="form-control mb-2" placeholder="State" />
                    </div>

                </div>

                <!-- VISIT DETAILS -->
                <h5 class="mt-3 mb-3">📅 Visit Details</h5>

                <div class="row">

                    <div class="col-md-4">
                        <input asp-for="Visit_Date" type="date" class="form-control mb-2" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Check_In_Time" type="datetime-local" class="form-control mb-2" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Check_Out_Time" type="datetime-local" class="form-control mb-2" />
                    </div>

                    <div class="col-md-6">
                        <input asp-for="Purpose_Of_Visit" class="form-control mb-2" placeholder="Purpose of Visit" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Person_To_Meet_Id" class="form-control mb-2" placeholder="Person To Meet ID" />
                    </div>

                    <div class="col-md-3">
                        <input asp-for="Person_Type" class="form-control mb-2" placeholder="Person Type" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Vehicle_Number" class="form-control mb-2" placeholder="Vehicle Number" />
                    </div>

                </div>

                <!-- APPROVAL -->
                <h5 class="mt-3 mb-3">✔ Approval</h5>

                <div class="row">

                    <div class="col-md-4">
                        <select asp-for="Is_Approved" class="form-control mb-2">
                            <option value="false">Not Approved</option>
                            <option value="true">Approved</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Approved_By" class="form-control mb-2" placeholder="Approved By" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Remarks" class="form-control mb-2" placeholder="Remarks" />
                    </div>

                </div>

                <!-- STATUS -->
                <h5 class="mt-3 mb-3">⚙ Status</h5>

                <div class="row">

                    <div class="col-md-4">
                        <select asp-for="Is_Deleted" class="form-control mb-2">
                            <option value="false">Active</option>
                            <option value="true">Deleted</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Updated_At" type="date" class="form-control mb-2" />
                    </div>

                    <div class="col-md-4">
                        <input asp-for="Updated_By" class="form-control mb-2" placeholder="Updated By" />
                    </div>

                </div>

                <!-- SUBMIT -->
                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success">
                        @(Model.Visitor_Id == 0 ? "➕ Add Visitor" : "✏️ Update Visitor")
                    </button>
                </div>

            </form>

        </div>

    </section>

</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}