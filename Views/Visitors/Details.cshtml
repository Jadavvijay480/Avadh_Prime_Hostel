@model AVADH_PRIME_Consume.Models.VisitorsModel

<!DOCTYPE html>
<html>
<head>
    <title>Visitor Profile</title>
    <link href="~/css/stylesheet.css" rel="stylesheet" />
</head>

<body>

    <main id="main" class="main">

        <!-- HEADER -->
        <div class="header-bar">
            <div class="header-title">VISITOR DETAILS</div>

            <div>
                <a asp-action="Edit"
                   asp-route-Visitor_Id="@Model.Visitor_Id"
                   class="btn">EDIT</a>

                <a asp-action="Index" class="btn">BACK</a>
            </div>
        </div>

        <!-- GRID -->
        <div class="main-grid">

            <!-- 1: PROFILE -->
            <div class="box student-box">
                <img src="~/assets/img/warden.png"
                     class="circle-img"
                     onerror="this.src='/images/no-image.png';" />

                <div class="student-name">
                    @Model.First_Name @Model.Last_Name
                </div>

                <div class="status">
                    @(Model.Check_Out_Time == null ? "Inside" : "Exited")
                </div>
            </div>

            <!-- 2: BASIC INFO -->
            <div class="box">
                <div class="title">Basic Info</div>
                <table class="kv">
                    <tr><td class="key">ID</td><td class="colon">:</td><td class="value">@Model.Visitor_Id</td></tr>
                    <tr><td class="key">First</td><td class="colon">:</td><td class="value">@Model.First_Name</td></tr>
                    <tr><td class="key">Last</td><td class="colon">:</td><td class="value">@Model.Last_Name</td></tr>
                    <tr><td class="key">Gender</td><td class="colon">:</td><td class="value">@Model.Gender</td></tr>
                </table>
            </div>

            <!-- 3: CONTACT -->
            <div class="box">
                <div class="title">Contact Info</div>
                <table class="kv">
                    <tr><td class="key">Phone</td><td class="colon">:</td><td class="value">@Model.Phone</td></tr>
                    <tr><td class="key">Email</td><td class="colon">:</td><td class="value">@Model.Email</td></tr>
                </table>
            </div>

            <!-- 4: ADDRESS -->
            <div class="box">
                <div class="title">Address</div>
                <table class="kv">
                    <tr><td class="key">Address</td><td class="colon">:</td><td class="value">@Model.Address</td></tr>
                    <tr><td class="key">City</td><td class="colon">:</td><td class="value">@Model.City</td></tr>
                    <tr><td class="key">State</td><td class="colon">:</td><td class="value">@Model.State</td></tr>
                    <tr><td class="key">Country</td><td class="colon">:</td><td class="value">@Model.Country</td></tr>
                </table>
            </div>

            <!-- 5: ID PROOF -->
            <div class="box">
                <div class="title">ID Proof</div>
                <table class="kv">
                    <tr><td class="key">Type</td><td class="colon">:</td><td class="value">@Model.Id_Proof_Type</td></tr>
                    <tr><td class="key">Number</td><td class="colon">:</td><td class="value">@Model.Id_Proof_Number</td></tr>
                </table>
            </div>

            <!-- 6: VISIT INFO -->
            <div class="box">
                <div class="title">Visit Info</div>
                <table class="kv">
                    <tr><td class="key">Date</td><td class="colon">:</td><td class="value">@Model.Visit_Date.ToString("dd-MM-yyyy")</td></tr>
                    <tr><td class="key">Check-In</td><td class="colon">:</td><td class="value">@Model.Check_In_Time.ToString("dd-MM-yyyy HH:mm")</td></tr>
                    <tr>
                        <td class="key">Check-Out</td>
                        <td class="colon">:</td>
                        <td class="value">
                            @(Model.Check_Out_Time?.ToString("dd-MM-yyyy HH:mm") ?? "-")
                        </td>
                    </tr>
                </table>
            </div>

            <!-- 7: PURPOSE -->
            <div class="box">
                <div class="title">Purpose</div>
                <p>@Model.Purpose_Of_Visit</p>
            </div>

            <!-- 8: MEETING -->
            <div class="box">
                <div class="title">Meeting Info</div>
                <table class="kv">
                    <tr><td class="key">Person ID</td><td class="colon">:</td><td class="value">@Model.Person_To_Meet_Id</td></tr>
                    <tr><td class="key">Type</td><td class="colon">:</td><td class="value">@Model.Person_Type</td></tr>
                </table>
            </div>

            <!-- 9: VEHICLE -->
            <div class="box">
                <div class="title">Vehicle</div>
                <table class="kv">
                    <tr><td class="key">Number</td><td class="colon">:</td><td class="value">@Model.Vehicle_Number</td></tr>
                </table>
            </div>

            <!-- 10: APPROVAL -->
            <div class="box">
                <div class="title">Approval</div>
                <table class="kv">
                    <tr><td class="key">Approved</td><td class="colon">:</td><td class="value">@(Model.Is_Approved ? "Yes" : "No")</td></tr>
                    <tr><td class="key">By</td><td class="colon">:</td><td class="value">@Model.Approved_By</td></tr>
                </table>
            </div>

            <!-- 11: AUDIT -->
            <div class="box">
                <div class="title">Audit</div>
                <table class="kv">
                    <tr><td class="key">Created</td><td class="colon">:</td><td class="value">@Model.Created_At.ToString("dd-MM-yyyy HH:mm")</td></tr>
                    <tr><td class="key">By</td><td class="colon">:</td><td class="value">@Model.Created_By</td></tr>
                    <tr>
                        <td class="key">Updated</td>
                        <td class="colon">:</td>
                        <td class="value">@(Model.Updated_At?.ToString("dd-MM-yyyy HH:mm") ?? "-")</td>
                    </tr>
                    <tr><td class="key">Updated By</td><td class="colon">:</td><td class="value">@Model.Updated_By</td></tr>
                </table>
            </div>

        </div>

    </main>

</body>
</html>


